<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Port Cybersecurity Lab — Tanger Med · 4 Real Simulations</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@300;400;500;600&family=Fira+Code:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   DESIGN: CLASSIFIED CYBER INTELLIGENCE TERMINAL
   Aesthetic: Military-grade dark ops + live terminal
   Fonts: Archivo Black (display) · Archivo (body) · Fira Code (mono)
   Color: Deep navy + electric cyan + alert red + success green
═══════════════════════════════════════════════════ */
:root{
  --void:#02060f;--abyss:#040b18;--deep:#070f22;--surf:#0b1830;--panel:#0f2040;
  --bdr:rgba(0,220,200,.07);--bdr2:rgba(0,220,200,.16);--bdr3:rgba(0,220,200,.28);
  --cyan:#00dcc8;--cyan2:#00b8a8;--ca:rgba(0,220,200,.08);--cb:rgba(0,220,200,.16);
  --red:#ff3355;--ra:rgba(255,51,85,.09);--rb:rgba(255,51,85,.2);
  --amber:#ffaa00;--aa:rgba(255,170,0,.1);
  --green:#00e676;--ga:rgba(0,230,118,.09);
  --blue:#4da8ff;--ba:rgba(77,168,255,.09);
  --violet:#cc77ff;--va:rgba(204,119,255,.09);
  --bone:#cce8ff;--warm:#7aa0c4;--fog:#1e3a58;--ghost:rgba(0,220,200,.03);
  --disp:'Archivo Black',impact,sans-serif;
  --body:'Archivo',system-ui,sans-serif;
  --mono:'Fira Code',monospace;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{background:var(--void);color:var(--warm);font-family:var(--body);overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:9998;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.028) 3px,rgba(0,0,0,.028) 4px);}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-track{background:var(--void);}::-webkit-scrollbar-thumb{background:var(--cyan2);}

/* ─── CURSOR ─── */
#CUR{position:fixed;width:7px;height:7px;background:var(--cyan);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);box-shadow:0 0 12px var(--cyan);}
#CUR2{position:fixed;width:30px;height:30px;border:1px solid rgba(0,220,200,.35);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:all .16s ease;}

/* ─── NAV ─── */
#nav{position:fixed;top:0;left:0;right:0;z-index:800;height:52px;background:rgba(2,6,15,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--bdr);}
.nw{max-width:1280px;margin:0 auto;padding:0 28px;height:100%;display:flex;align-items:center;gap:0;}
.nlogo{font-family:var(--mono);font-size:10.5px;letter-spacing:2px;color:var(--cyan);cursor:pointer;margin-right:32px;display:flex;align-items:center;gap:8px;text-transform:uppercase;}
.nls{width:20px;height:20px;border:1.5px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;}
.nlinks{display:flex;gap:2px;flex:1;flex-wrap:wrap;}
.nl{font-family:var(--mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--warm);padding:5px 11px;border:1px solid transparent;background:none;cursor:pointer;transition:all .18s;}
.nl:hover{color:var(--bone);border-color:var(--bdr2);}
.nl.on{color:var(--cyan);border-color:var(--cb);background:var(--ca);}
.nstatus{margin-left:auto;font-family:var(--mono);font-size:8.5px;color:var(--fog);display:flex;align-items:center;gap:5px;letter-spacing:1px;}
.npulse{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.3;transform:scale(.7);}}

/* ─── PAGE SYSTEM ─── */
.pg{display:none;min-height:100vh;}
.pg.on{display:block;animation:fadein .35s ease both;}
@keyframes fadein{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* ─── LAYOUT ─── */
.W{max-width:1280px;margin:0 auto;padding:0 28px;}
.SP{padding:56px 0;}.SP2{padding:40px 0;}

/* ─── TYPE ─── */
.DXL{font-family:var(--disp);font-size:clamp(60px,8vw,128px);line-height:.92;color:var(--bone);letter-spacing:-1px;}
.DL{font-family:var(--disp);font-size:clamp(42px,5.5vw,88px);line-height:.95;color:var(--bone);}
.DM{font-family:var(--disp);font-size:clamp(30px,4vw,56px);line-height:1;color:var(--bone);}
.DS{font-family:var(--disp);font-size:clamp(20px,2.5vw,34px);line-height:1.05;color:var(--bone);}
.tc{color:var(--cyan);}.tr{color:var(--red);}.ta{color:var(--amber);}.tg{color:var(--green);}.tb{color:var(--blue);}.tv{color:var(--violet);}
.BL{font-size:17px;line-height:1.82;}.BM{font-size:14.5px;line-height:1.78;}.BS{font-size:12.5px;line-height:1.7;color:var(--fog);}
strong{color:var(--bone);font-weight:600;}

/* ─── EYEBROW ─── */
.eye{font-family:var(--mono);font-size:8.5px;letter-spacing:3.5px;text-transform:uppercase;color:var(--cyan);display:flex;align-items:center;gap:9px;margin-bottom:12px;}
.eye::before{content:'//';color:var(--fog);}
.eye.R{color:var(--red);}.eye.R::before{color:rgba(255,51,85,.3);}
.eye.A{color:var(--amber);}.eye.A::before{color:rgba(255,170,0,.3);}
.eye.G{color:var(--green);}.eye.G::before{color:rgba(0,230,118,.3);}
.eye.V{color:var(--violet);}.eye.V::before{color:rgba(204,119,255,.3);}
.eye.B{color:var(--blue);}.eye.B::before{color:rgba(77,168,255,.3);}

/* ─── REVEAL ─── */
.rv{opacity:0;transform:translateY(20px);transition:opacity .65s ease,transform .65s ease;}
.rv.vis{opacity:1;transform:none;}

/* ─── HERO ─── */
.hero{min-height:100vh;position:relative;display:flex;align-items:center;padding-top:52px;overflow:hidden;}
#heroCanvas{position:absolute;inset:0;z-index:0;}
.hgrid{position:absolute;inset:0;z-index:1;pointer-events:none;
  background-image:linear-gradient(rgba(0,220,200,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,220,200,.025) 1px,transparent 1px);
  background-size:80px 80px;
  mask-image:radial-gradient(ellipse 70% 65% at 20% 50%,black,transparent);}
.hvig{position:absolute;inset:0;z-index:2;pointer-events:none;background:radial-gradient(ellipse 120% 90% at 50% 110%,transparent 25%,var(--void) 72%);}
.hcontent{position:relative;z-index:3;padding:44px 0 52px;}
/* Hero: 2-column layout */
.h2col{display:grid;grid-template-columns:1fr 480px;gap:44px;align-items:center;}
@media(max-width:1100px){.h2col{grid-template-columns:1fr 380px;gap:28px;}}
@media(max-width:820px){.h2col{grid-template-columns:1fr;}}
.hleft{}
.hright{}
.hbadge{display:inline-flex;align-items:center;gap:9px;background:var(--ca);border:1px solid var(--cb);padding:4px 14px 4px 8px;margin-bottom:16px;}
.hbdot{width:5px;height:5px;border-radius:50%;background:var(--cyan);animation:pulse 1.5s infinite;}
.hbt{font-family:var(--mono);font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--cyan);}
.hkicker{font-family:var(--mono);font-size:clamp(11px,1.3vw,13px);letter-spacing:6px;text-transform:uppercase;color:var(--fog);margin-bottom:6px;}
.htags{display:flex;flex-wrap:wrap;gap:5px;margin:16px 0 20px;}
.htag{font-family:var(--mono);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;padding:3px 10px;border:1px solid;cursor:default;transition:transform .2s;}
.htag:hover{transform:translateY(-2px);}
.ht0{color:var(--cyan);border-color:var(--cb);background:var(--ca);}
.ht1{color:var(--red);border-color:var(--rb);background:var(--ra);}
.ht2{color:var(--amber);border-color:rgba(255,170,0,.22);background:var(--aa);}
.ht3{color:var(--blue);border-color:rgba(77,168,255,.18);background:var(--ba);}
.ht4{color:var(--violet);border-color:rgba(204,119,255,.18);background:var(--va);}
.ht5{color:var(--green);border-color:rgba(0,230,118,.18);background:var(--ga);}

/* stats bar */
.hstats{display:flex;gap:0;border:1px solid var(--bdr2);overflow:hidden;width:100%;margin-top:20px;}
.hstat{flex:1;padding:14px 16px;background:var(--surf);border-right:1px solid var(--bdr);text-align:center;position:relative;}
.hstat:last-child{border-right:none;}
.hstat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.hs0::before{background:var(--cyan);}
.hs1::before{background:var(--red);}
.hs2::before{background:var(--amber);}
.hs3::before{background:var(--violet);}
.hsv{font-family:var(--disp);font-size:28px;line-height:1;display:block;margin-bottom:3px;}
.hs0 .hsv{color:var(--cyan);}
.hs1 .hsv{color:var(--red);}
.hs2 .hsv{color:var(--amber);}
.hs3 .hsv{color:var(--violet);}
.hsl{font-family:var(--mono);font-size:7.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--fog);}

/* ─── TERMINAL ─── */
.term{background:#000d1f;border:1px solid var(--bdr);overflow:hidden;}
.tbar{background:var(--deep);padding:8px 14px;display:flex;align-items:center;gap:6px;border-bottom:1px solid var(--bdr);}
.td1{width:9px;height:9px;border-radius:50%;background:#ff5f57;}
.td2{width:9px;height:9px;border-radius:50%;background:#febc2e;}
.td3{width:9px;height:9px;border-radius:50%;background:#28c840;}
.ttit{font-family:var(--mono);font-size:9px;color:var(--fog);margin-left:auto;letter-spacing:1px;}
.tbody{padding:12px 14px;font-family:var(--mono);font-size:10px;line-height:1.85;min-height:210px;}
.tbody div{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lc{color:rgba(0,180,160,.3);}.lg{color:#3ddc84;}.lr{color:#ff6b7a;}.la{color:#ffc857;}.lb{color:var(--blue);}.lp{color:var(--violet);}.lw{color:var(--bone);}.lm{color:var(--warm);}
.blink::after{content:'▌';animation:pulse .75s step-start infinite;color:var(--cyan);}

/* ─── CARDS/PANELS ─── */
.card{background:var(--abyss);border:1px solid var(--bdr);transition:background .22s,border-color .22s;}
.card:hover{background:var(--deep);border-color:var(--bdr2);}
.panel{background:var(--deep);border:1px solid var(--bdr);}

/* ─── CODE BLOCK ─── */
pre.CB,div.CB{background:#000d1f;border:1px solid rgba(0,220,200,.1);border-left:3px solid var(--cyan);padding:18px 20px;font-family:var(--mono);font-size:11.5px;line-height:1.95;overflow-x:auto;margin:12px 0;white-space:pre-wrap;word-break:break-word;tab-size:4;border-radius:0;}
pre.CB.R,div.CB.R{border-left-color:var(--red);}
pre.CB.A,div.CB.A{border-left-color:var(--amber);}
pre.CB.G,div.CB.G{border-left-color:var(--green);}
pre.CB.V,div.CB.V{border-left-color:var(--violet);}
.CB .CC{color:rgba(100,155,185,.55);font-style:italic;}
.CB .CMD{color:#5ec9ff;font-weight:600;}
.CB .FLG{color:#7dd87a;}
.CB .VAL{color:#e8d28a;}
.CB .OUT{color:#9db8c8;}
.CB .OK{color:#3ddc84;font-weight:500;}
.CB .ERR{color:#ff7085;font-weight:600;}
.CB .WRN{color:#ffc857;}

/* ─── INFO BOX ─── */
.IB{border:1px solid;padding:16px 18px;margin:14px 0;border-left:3px solid;}
.IB.C{border-color:rgba(0,220,200,.18);background:var(--ca);border-left-color:var(--cyan);}
.IB.R{border-color:var(--rb);background:var(--ra);border-left-color:var(--red);}
.IB.A{border-color:rgba(255,170,0,.18);background:var(--aa);border-left-color:var(--amber);}
.IB.G{border-color:rgba(0,230,118,.18);background:var(--ga);border-left-color:var(--green);}
.IB.V{border-color:rgba(204,119,255,.18);background:var(--va);border-left-color:var(--violet);}
.ibl{font-family:var(--mono);font-size:8px;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.IB.C .ibl{color:var(--cyan);}
.IB.R .ibl{color:var(--red);}
.IB.A .ibl{color:var(--amber);}
.IB.G .ibl{color:var(--green);}
.IB.V .ibl{color:var(--violet);}
.IB p{font-size:13.5px;line-height:1.75;}

/* ─── TAGS ─── */
.tag{font-family:var(--mono);font-size:8px;letter-spacing:1px;text-transform:uppercase;padding:2px 8px;border:1px solid;display:inline-block;margin:2px;}
.t0{color:var(--cyan);border-color:var(--cb);background:var(--ca);}
.t1{color:var(--red);border-color:var(--rb);background:var(--ra);}
.t2{color:var(--amber);border-color:rgba(255,170,0,.22);background:var(--aa);}
.t3{color:var(--blue);border-color:rgba(77,168,255,.18);background:var(--ba);}
.t4{color:var(--violet);border-color:rgba(204,119,255,.18);background:var(--va);}
.t5{color:var(--green);border-color:rgba(0,230,118,.18);background:var(--ga);}
.tsm{font-family:var(--mono);font-size:8px;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border:1px solid;display:inline-block;margin:2px;}

/* ─── CVSS ─── */
.CVSS{font-family:var(--mono);font-size:10.5px;font-weight:700;padding:2px 9px;display:inline-block;}
.CVSS.C{color:var(--red);background:var(--ra);border:1px solid var(--rb);}
.CVSS.H{color:var(--amber);background:var(--aa);border:1px solid rgba(255,170,0,.22);}
.CVSS.M{color:var(--blue);background:var(--ba);border:1px solid rgba(77,168,255,.18);}
.CVSS.L{color:var(--green);background:var(--ga);border:1px solid rgba(0,230,118,.18);}

/* ─── TABLE ─── */
table.T{width:100%;border-collapse:collapse;}
table.T th{background:var(--deep);padding:11px 14px;font-family:var(--mono);font-size:8.5px;letter-spacing:2px;text-transform:uppercase;color:var(--fog);text-align:left;border:1px solid var(--bdr);}
table.T td{padding:12px 14px;border:1px solid var(--bdr);font-size:13px;vertical-align:middle;}
table.T tr:hover td{background:rgba(0,220,200,.02);}
.cve-id{font-family:var(--mono);font-size:10.5px;color:var(--blue);}

/* ─── DETAIL LAYOUT ─── */
.DTL{display:grid;grid-template-columns:1fr 320px;gap:52px;}
@media(max-width:1000px){.DTL{grid-template-columns:1fr;}}
.SB{position:sticky;top:66px;height:fit-content;}
.SBC{background:var(--abyss);border:1px solid var(--bdr);overflow:hidden;margin-bottom:12px;}
.SBH{background:var(--deep);padding:9px 13px;font-family:var(--mono);font-size:8.5px;letter-spacing:2px;text-transform:uppercase;color:var(--warm);border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:6px;}
.SBH::before{content:'▸';color:var(--cyan);font-size:8px;}
.SBB{padding:13px;}
.KPI{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bdr);}
.KPI:last-child{border-bottom:none;}
.KL{font-family:var(--mono);font-size:9px;color:var(--fog);letter-spacing:.5px;}
.KV{font-family:var(--disp);font-size:22px;}

/* ─── STEP ─── */
.step{display:grid;grid-template-columns:38px 1fr;border:1px solid var(--bdr);overflow:hidden;margin-bottom:3px;transition:border-color .2s;}
.step:hover{border-color:var(--bdr2);}
.stepN{display:flex;align-items:flex-start;justify-content:center;padding-top:17px;font-family:var(--mono);font-size:11px;font-weight:700;color:white;}
.N0{background:var(--cyan2);}.N1{background:#c01828;}.N2{background:#b07200;}.N3{background:#1864a0;}.N4{background:#6028a8;}.N5{background:#0a7840;}
.stepB{padding:15px 17px;background:var(--abyss);}
.stepB h4{font-size:14px;font-weight:700;color:var(--bone);margin-bottom:6px;}
.stepB p{font-size:13px;line-height:1.73;}

/* ─── ALERTS ─── */
.AL{display:flex;flex-direction:column;gap:3px;margin:10px 0;}
.AE{display:grid;grid-template-columns:42px 96px 1fr;border:1px solid var(--bdr);overflow:hidden;}
.AEL{display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:9px;font-weight:700;color:white;padding:7px 0;}
.LC{background:rgba(255,51,85,.75);}
.LH{background:rgba(255,170,0,.7);}
.LM{background:rgba(77,168,255,.6);}
.LG{background:rgba(0,230,118,.55);}
.AER{display:flex;align-items:center;padding:0 8px;font-family:var(--mono);font-size:9px;background:var(--panel);border-right:1px solid var(--bdr);}
.AEM{display:flex;align-items:center;padding:8px 11px;font-family:var(--mono);font-size:9.5px;background:var(--abyss);}

/* ─── SIEM LOG ─── */
.SIEM{background:#000d1f;border:1px solid var(--bdr);border-top:2px solid var(--cyan);overflow:hidden;margin:14px 0;}
.SIEMH{background:var(--deep);padding:7px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--bdr);}
.SIEMT{font-family:var(--mono);font-size:8.5px;color:var(--cyan);letter-spacing:1px;}
.SIEML{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:8px;color:var(--green);}
.SIEMB{padding:10px 12px;font-family:var(--mono);font-size:9.5px;line-height:2;}
.SL{display:flex;gap:10px;flex-wrap:wrap;border-bottom:1px solid rgba(0,220,200,.04);padding:1px 0;}
.SL:last-child{border-bottom:none;}
.SLT{color:var(--fog);min-width:58px;flex-shrink:0;}
.SLEV{font-weight:700;min-width:78px;flex-shrink:0;}
.slC{color:var(--red);}.slH{color:var(--amber);}.slI{color:var(--cyan);}.slG{color:var(--green);}
.SLM{color:var(--warm);}

/* ─── STATS ROW ─── */
.STATS{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--bdr);border:1px solid var(--bdr);margin:18px 0;}
.SC{background:var(--abyss);padding:16px;text-align:center;}
.SCV{font-family:var(--disp);font-size:28px;font-weight:900;line-height:1;display:block;margin-bottom:3px;}
.SCL{font-family:var(--mono);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--fog);}

/* ─── BAN TIMELINE ─── */
.BAN{display:flex;flex-direction:column;gap:6px;}
.BANI{display:grid;grid-template-columns:76px 1fr auto;align-items:center;gap:10px;background:var(--abyss);border:1px solid var(--bdr);padding:11px 13px;}
.BN{font-family:var(--mono);font-size:9px;color:var(--fog);}
.BD{font-size:12.5px;}
.BV{font-family:var(--disp);font-size:22px;}

/* ─── INJECT DEMO ─── */
.INJECD{background:var(--void);border:1px solid rgba(204,119,255,.2);overflow:hidden;margin:12px 0;}
.INJEDH{background:var(--deep);padding:8px 13px;font-family:var(--mono);font-size:8.5px;letter-spacing:2px;text-transform:uppercase;color:var(--fog);border-bottom:1px solid var(--bdr);}
.INJEDB{padding:12px 14px;font-family:var(--mono);font-size:11px;line-height:2.3;}
.Is{color:var(--blue);}.Io{color:var(--green);}.Ia{color:var(--fog);margin:0 7px;}.If{color:var(--red);font-weight:700;}.Ist{color:var(--amber);font-size:9.5px;}

/* ─── NETWORK DIAGRAM ─── */
.NETD{background:var(--deep);border:1px solid var(--bdr);padding:24px;margin:20px 0;overflow-x:auto;}
.NDTIT{font-family:var(--mono);font-size:8.5px;letter-spacing:2px;text-transform:uppercase;color:var(--fog);margin-bottom:18px;}
.NDROW{display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;}
.NDNODE{display:flex;flex-direction:column;align-items:center;gap:5px;}
.NDI{width:54px;height:54px;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:22px;}
.NDI.R{border-color:var(--red);}.NDI.C{border-color:var(--cyan);}.NDI.V{border-color:var(--violet);}
.NDL{font-family:var(--mono);font-size:8.5px;text-align:center;color:var(--bone);text-transform:uppercase;letter-spacing:1px;}
.NDIP{font-family:var(--mono);font-size:8px;color:var(--fog);}
.NDCONN{padding:0 14px;display:flex;flex-direction:column;align-items:center;gap:5px;}
.NDLINE{height:2px;width:90px;position:relative;}
.NDLINE::after{content:'▶';position:absolute;right:-7px;top:-9px;font-size:11px;}
.NDLINE.R{background:var(--red);}.NDLINE.R::after{color:var(--red);}
